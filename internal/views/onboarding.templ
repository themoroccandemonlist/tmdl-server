							<div class="inline-flex gap-2 self-stretch">
								<span class="flex-1 h-1 rounded-[14px] bg-[#FF2E2C]"></span>
								<span class="flex-1 h-1 rounded-[14px] bg-[#FF2E2C]"></span>
								<span class="flex-1 h-1 rounded-[14px] bg-[#FF2E2C]"></span>
								<span class="flex-1 h-1 rounded-[14px] bg-[#FF2E2C]"></span>
								<span class="flex-1 h-1 rounded-[14px] bg-[#281818]"></span>
							</div>
							<div class="flex flex-col gap-2 justify-start">
								<span class="text-2xl font-semibold text-[#FFFFFF] leading-[29px]">Your gamemode</span>
								<span class="text-sm font-medium text-[#B3B3B3] leading-[17px]">Which gamemode do you mainly play?</span>
							</div>
							<div class="inline-flex gap-4">
								<button type="button" @click="gamemode = 'CLASSIC'" class="w-[132px] flex flex-col items-center justify-center gap-2 px-2 py-6 rounded-lg border cursor-pointer" :class="gamemode === 'CLASSIC' ? 'border-[#FF2E2C] bg-[#FF2E2C0A]' : 'border-[#281818] bg-[#110000]'">
									<div class="p-1 rounded-md" :class="gamemode === 'CLASSIC' ? 'text-[#FF2E2C] bg-[#FF2E2C26]' : 'text-[#4D4D4D] bg-[#B3B3B326]'">
										@components.Gamepad(16, 16)
									</div>
									<span class="text-sm font-medium" :class="gamemode === 'CLASSIC' ? 'text-[#FF2E2C]' : 'text-[#4D4D4D]'">Classic</span>
								</button>
								<button type="button" @click="gamemode = 'PLATFORMER'" class="w-[132px] flex flex-col items-center justify-center gap-2 px-2 py-6 rounded-lg border cursor-pointer" :class="gamemode === 'PLATFORMER' ? 'border-[#FF2E2C] bg-[#FF2E2C0A]' : 'border-[#281818] bg-[#110000]'">
									<div class="p-1 rounded-md" :class="gamemode === 'PLATFORMER' ? 'text-[#FF2E2C] bg-[#FF2E2C26]' : 'text-[#4D4D4D] bg-[#B3B3B326]'">
										@components.Joystick(16, 16)
									</div>
									<span class="text-sm font-medium" :class="gamemode === 'PLATFORMER' ? 'text-[#FF2E2C]' : 'text-[#4D4D4D]'">Platformer</span>
								</button>
								<button type="button" @click="gamemode = 'BOTH'" class="w-[132px] flex flex-col items-center justify-center gap-2 px-2 py-6 rounded-lg border cursor-pointer" :class="gamemode === 'BOTH' ? 'border-[#FF2E2C] bg-[#FF2E2C0A]' : 'border-[#281818] bg-[#110000]'">
									<div class="inline-flex gap-2">
										<span class="p-1 rounded-md" :class="gamemode === 'BOTH' ? 'text-[#FF2E2C] bg-[#FF2E2C26]' : 'text-[#4D4D4D] bg-[#B3B3B326]'">
											@components.Gamepad(16, 16)
										</span>
										<span class="p-1 rounded-md" :class="gamemode === 'BOTH' ? 'text-[#FF2E2C] bg-[#FF2E2C26]' : 'text-[#4D4D4D] bg-[#B3B3B326]'">
											@components.Joystick(16, 16)
										</span>
									</div>
									<span class="text-sm font-medium" :class="gamemode === 'BOTH' ? 'text-[#FF2E2C]' : 'text-[#4D4D4D]'">Both</span>
								</button>
							</div>
							<input type="hidden" name="gamemode" :value="gamemode"/>
						</div>
						<div class="inline-flex gap-4">
							<button @click="step -= 1" class="basis-1/3 inline-flex gap-1 justify-center items-center text-[#CFCCCC] rounded-3xl pl-4.5 pr-5.5 py-2.5 cursor-pointer h-9.5 bg-[#1A0A0A] border border-[#281818]">
								<span class="text-sm font-medium leading-none">Back</span>
							</button>
							<button @click="step += 1" class="basis-2/3 inline-flex gap-1 justify-center items-center text-[#FFFFFF] rounded-3xl pl-4.5 pr-5.5 py-2.5 cursor-pointer h-9.5 bg-[#FF2E2C] shadow-[0px_8px_16px_rgba(255,46,44,0.2),0px_-1px_2px_#ff2e2c_inset,0px_-6px_6px_rgba(255,255,255,0.25)_inset,0px_5px_12.6px_#c30200_inset]">
								<span class="text-sm font-medium leading-none">Continue</span>
							</button>
						</div>
					</div>
					<div x-show="step === 5" class="flex flex-col p-6 justify-between w-[478px] h-[539px] bg-[#180808] rounded-l-xl">
						<div class="flex flex-col gap-8">
							<div class="inline-flex gap-2 self-stretch">
								<span class="flex-1 h-1 rounded-[14px] bg-[#FF2E2C]"></span>
								<span class="flex-1 h-1 rounded-[14px] bg-[#FF2E2C]"></span>
								<span class="flex-1 h-1 rounded-[14px] bg-[#FF2E2C]"></span>
								<span class="flex-1 h-1 rounded-[14px] bg-[#FF2E2C]"></span>
								<span class="flex-1 h-1 rounded-[14px] bg-[#FF2E2C]"></span>
							</div>
							<div class="flex flex-col gap-2 justify-start">
								<span class="text-2xl font-semibold text-[#FFFFFF] leading-[29px]">Your device</span>
								<span class="text-sm font-medium text-[#B3B3B3] leading-[17px]">Which device do you mainly play with?</span>
							</div>
							<div class="inline-flex gap-4">
								<button type="button" @click="device = 'PC'" class="w-[132px] flex flex-col items-center justify-center gap-2 px-2 py-6 rounded-lg border cursor-pointer" :class="device === 'PC' ? 'border-[#FF2E2C] bg-[#FF2E2C0A]' : 'border-[#281818] bg-[#110000]'">
									<div class="p-1 rounded-md" :class="device === 'PC' ? 'text-[#FF2E2C] bg-[#FF2E2C26]' : 'text-[#4D4D4D] bg-[#B3B3B326]'">
										@components.Computer(16, 16)
									</div>
									<span class="text-sm font-medium" :class="device === 'PC' ? 'text-[#FF2E2C]' : 'text-[#4D4D4D]'">PC</span>
								</button>
								<button type="button" @click="device = 'MOBILE'" class="w-[132px] flex flex-col items-center justify-center gap-2 px-2 py-6 rounded-lg border cursor-pointer" :class="device === 'MOBILE' ? 'border-[#FF2E2C] bg-[#FF2E2C0A]' : 'border-[#281818] bg-[#110000]'">
									<div class="p-1 rounded-md" :class="device === 'MOBILE' ? 'text-[#FF2E2C] bg-[#FF2E2C26]' : 'text-[#4D4D4D] bg-[#B3B3B326]'">
										@components.Smartphone(16, 16)
									</div>
									<span class="text-sm font-medium" :class="device === 'MOBILE' ? 'text-[#FF2E2C]' : 'text-[#4D4D4D]'">Mobile</span>
								</button>
								<button type="button" @click="device = 'BOTH'" class="w-[132px] flex flex-col items-center justify-center gap-2 px-2 py-6 rounded-lg border cursor-pointer" :class="device === 'BOTH' ? 'border-[#FF2E2C] bg-[#FF2E2C0A]' : 'border-[#281818] bg-[#110000]'">
									<div class="inline-flex gap-2">
										<span class="p-1 rounded-md" :class="device === 'BOTH' ? 'text-[#FF2E2C] bg-[#FF2E2C26]' : 'text-[#4D4D4D] bg-[#B3B3B326]'">
											@components.Computer(16, 16)
										</span>
										<span class="p-1 rounded-md" :class="device === 'BOTH' ? 'text-[#FF2E2C] bg-[#FF2E2C26]' : 'text-[#4D4D4D] bg-[#B3B3B326]'">
											@components.Smartphone(16, 16)
										</span>
									</div>
									<span class="text-sm font-medium" :class="device === 'BOTH' ? 'text-[#FF2E2C]' : 'text-[#4D4D4D]'">Both</span>
								</button>
							</div>
							<input type="hidden" name="device" :value="device"/>
						</div>
						<div class="inline-flex gap-4">
							<button type="button" @click="step -= 1" class="basis-1/3 inline-flex gap-1 justify-center items-center text-[#CFCCCC] rounded-3xl pl-4.5 pr-5.5 py-2.5 cursor-pointer h-9.5 bg-[#1A0A0A] border border-[#281818]">
								<span class="text-sm font-medium leading-none">Back</span>
							</button>
							<button type="submit" class="basis-2/3 inline-flex gap-1 justify-center items-center text-[#FFFFFF] rounded-3xl pl-4.5 pr-5.5 py-2.5 cursor-pointer h-9.5 bg-[#FF2E2C] shadow-[0px_8px_16px_rgba(255,46,44,0.2),0px_-1px_2px_#ff2e2c_inset,0px_-6px_6px_rgba(255,255,255,0.25)_inset,0px_5px_12.6px_#c30200_inset]">
								<span class="text-sm font-medium leading-none">Finish</span>
							</button>
						</div>
					</div>
					<div class="relative">
						<img src="/static/assets/onboarding-card.png"/>
						<div x-show="step != 1" class="absolute inset-0 flex items-center justify-center">
							<div class="inline-flex gap-2 items-center px-4 pt-8 pb-2 h-[122px] w-[430px] border border-[#281818] rounded-xl bg-[linear-gradient(0deg,rgba(17,0,0,0.70)_0%,rgba(17,0,0,0.20)_100%),linear-gradient(180deg,rgba(17,0,0,0.00)_-7.77%,rgba(17,0,0,0.60)_53.31%),url(/static/assets/default-cover.png)] bg-cover bg-center bg-no-repeat">
								<img class="rounded-full size-16 cursor-pointer" src="/static/assets/default-pfp.jpg"/>
								<div class="flex flex-col gap-2">
									<div class="inline-flex gap-2">
                                        <div x-show="gamemode === 'CLASSIC' || gamemode ==='BOTH'" class="inline-flex gap-1.25 px-2 h-[26px] text-xs font-medium text-[#FF2E2C] bg-[#C3020026] border border-[#C3020040] rounded-4xl">
                                            <span class="flex items-center">@components.Gamepad(12, 12)</span>
                                            <span class="flex items-center">Classic</span>
                                        </div>
                                        <div x-show="gamemode === 'PLATFORMER' || gamemode ==='BOTH'" class="inline-flex gap-1.25 px-2 h-[26px] text-xs font-medium text-[#4A9EFF] bg-[#4A9EFF26] border border-[#4A9EFF40] rounded-4xl">
                                            <span class="flex items-center">@components.Joystick(12, 12)</span>
                                            <span class="flex items-center">Platformer</span>
                                        </div>
                                    </div>
									<div class="inline-flex gap-2 items-center">
										<span x-text="username.trim() !== '' ? username : 'laggypotato'" class="text-xl font-semibold text-[#FFFFFF]"></span>
										<div class="inline-flex gap-2 pt-1">
											<span class="text-[#EEEEEE]" x-show="discord.trim() !== ''">
												@components.DiscordFull(12, 12)
											</span>
											<span class="text-[#EEEEEE]" x-show="youtube.trim() !== ''">
												@components.YouTubeFull(12, 12)
											</span>
											<span class="text-[#EEEEEE]" x-show="twitter.trim() !== ''">
												@components.TwitterFull(12, 12)
											</span>
											<span class="text-[#EEEEEE]" x-show="twitch.trim() !== ''">
												@components.TwitchFull(12, 12)
											</span>
										</div>
									</div>
									<div class="inline-flex gap-1 text-[#666666]">
										<div class="flex justify-center items-center leading-none">
											@components.Location(12, 12)
										</div>
										<span x-text="regionOptions.find(o => o.value === region)?.label ?? 'Morocco'" class="text-xs font-medium leading-none"></span>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</form>
		</body>
	}
}
